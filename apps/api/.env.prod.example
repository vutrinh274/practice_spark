# Copy this to .env.prod and fill in real values
# NEVER commit .env.prod to version control

# Spark Connect — internal Docker network
SPARK_CONNECT_URL=sc://spark-connect:15002
SPARK_PROBLEMS_DIR=/problems

# Database — mounted volume
DB_PATH=/app/data/spark_practice.db

# Clerk — get from clerk.com dashboard (use PRODUCTION keys)
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# Stripe — get from stripe.com dashboard (use LIVE keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_SYNC_INTERVAL_MINUTES=5

# Admin secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=

# CORS — your frontend domain (Vercel URL)
CORS_ORIGINS=https://yourdomain.com,https://your-vercel-app.vercel.app
