# Local development env vars for the API.
# Copy to apps/api/.env and fill in your dev keys.
# For production values, see apps/api/.env.prod.example.

# Spark Connect — host port published by docker-compose.yml.
SPARK_CONNECT_URL=sc://localhost:15002

# Path to the problems dir as seen by Spark Connect *inside the container*.
# docker-compose.yml mounts ./packages/problems -> /problems.
SPARK_PROBLEMS_DIR=/problems

# Path to the problems dir on the host machine (relative to apps/api/,
# since `make api` runs uvicorn from that directory).
PROBLEMS_DIR=../../packages/problems

# SQLite DB file (relative to apps/api/) — created on first run.
DB_PATH=spark_practice.db

# Clerk — use Development keys from the Clerk dashboard.
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe — use test keys from the Stripe dashboard.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_SYNC_INTERVAL_MINUTES=5

# Admin secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=

# CORS — local Next.js dev server.
CORS_ORIGINS=http://localhost:3000
