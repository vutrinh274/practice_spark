# Local development env vars for the API.
# Copy to apps/api/.env and fill in the Clerk keys when you need sign-in.
# For production values, see apps/api/.env.prod.example.
#
# Minimum to boot `make api`: nothing — the defaults below work as-is.
# To use sign-in:               fill in CLERK_SECRET_KEY + NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
# To test Stripe sync:          fill in STRIPE_SECRET_KEY (leave empty otherwise — sync is skipped).

# ---------- Spark Connect ----------
# Make sure `make spark` is running — that publishes port 15002 on the host.
SPARK_CONNECT_URL=sc://localhost:15002

# Path to the problems dir as seen by Spark Connect *inside the container*.
# docker-compose.yml mounts ./packages/problems -> /problems.
SPARK_PROBLEMS_DIR=/problems

# Path to the problems dir on the host (relative to apps/api/, since
# `make api` runs uvicorn from that directory).
PROBLEMS_DIR=../../packages/problems

# ---------- Database ----------
# SQLite file (relative to apps/api/) — created on first run.
DB_PATH=spark_practice.db

# ---------- Auth (Clerk) ----------
# Development keys from the Clerk dashboard. Required for sign-in to work.
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ---------- Stripe (optional) ----------
# Leave empty to skip the background subscriber sync locally.
# Set to a Stripe test secret (sk_test_...) when working on subscriber logic.
STRIPE_SECRET_KEY=
STRIPE_SYNC_INTERVAL_MINUTES=5

# ---------- Misc ----------
# Secret for admin endpoints (/admin/*). Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=

# CORS — local Next.js dev server.
CORS_ORIGINS=http://localhost:3000
